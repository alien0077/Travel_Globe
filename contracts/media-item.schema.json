{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://travelglobe.app/schemas/media-item.schema.json",
  "title": "MediaItem",
  "type": "object",
  "required": ["id", "journeyId", "kind", "createdAt", "source", "metadata"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "journeyId": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "enum": ["photo", "video", "thumbnail"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "source": { "type": "string", "enum": ["photoLibrary", "imported", "generated"] },
    "metadata": { "type": "object", "additionalProperties": true }
  }
}
